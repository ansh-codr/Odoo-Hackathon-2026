rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        getUserData().role == role;
    }
    
    function isManagerOrAdmin() {
      return hasRole('admin') || hasRole('asset_manager');
    }

    // Rules for each collection
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (
        // Only admin can change the role field
        (request.resource.data.role == resource.data.role) || hasRole('admin')
      );
      allow delete: if hasRole('admin');
    }
    
    match /departments/{deptId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('admin');
    }
    
    match /assetCategories/{catId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('admin');
    }
    
    match /assets/{assetId} {
      allow read: if isAuthenticated();
      allow write: if isManagerOrAdmin();
    }
    
    match /allocations/{allocId} {
      allow read: if isAuthenticated();
      allow write: if isManagerOrAdmin();
    }
    
    match /transferRequests/{reqId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    match /bookings/{bookingId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    match /maintenanceRequests/{reqId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    match /auditCycles/{cycleId} {
      allow read: if isAuthenticated();
      allow write: if hasRole('admin');
    }
    
    match /auditRecords/{recordId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated();
    }
    
    match /activityLogs/{logId} {
      allow read: if isManagerOrAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
